*.mex*
work/

# ── Generated data ─────────────────────────────────────────────────────────────
*.csv
*.log

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Keep these regardless ─────────────────────────────────────────────────────
!*.md
!requirements.txt
