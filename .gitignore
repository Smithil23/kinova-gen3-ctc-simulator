# ── Original entries (kept exactly) ───────────────────────────────────────────
*.asv
*.slxc
slprj/
*.autosave
codegen/
*.txt
ghp_*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

